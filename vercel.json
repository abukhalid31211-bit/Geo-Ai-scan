{
  "buildCommand": "pnpm install && pnpm --filter @workspace/samgold-web run build",
  "outputDirectory": "artifacts/samgold-web/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "env": {
    "BASE_PATH": "/"
  }
}
